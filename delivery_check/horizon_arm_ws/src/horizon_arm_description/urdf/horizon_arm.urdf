    </visual>
    <collision>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_1.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="Link_2">
    <visual>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_2.STL"/>
      </geometry>
      <material name="horizon_light"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_2.STL"/>
