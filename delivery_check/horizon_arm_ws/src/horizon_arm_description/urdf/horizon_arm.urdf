    <child link="Link_6"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.792527" upper="2.792527" effort="8.0" velocity="2.0"/>
  </joint>

  <joint name="tool0_fixed_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="Link_6"/>
    <child link="tool0"/>
  </joint>

  <joint name="tcp_fixed_joint" type="fixed">
    <origin xyz="0 0.015 0.09925" rpy="0 0 0"/>
    <parent link="tool0"/>
    <child link="tcp_link"/>
