  </link>

  <link name="tool0"/>
  <link name="tcp_link"/>

  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.0935" rpy="0 0 -3.1416"/>
    <parent link="base_link"/>
    <child link="Link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.094395" upper="2.094395" effort="10.0" velocity="1.5"/>
  </joint>

  <joint name="joint_2" type="revolute">
    <origin xyz="0 0 0.037" rpy="1.5708 -1.5708 0"/>
    <parent link="Link_1"/>
    <child link="Link_2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.047198" upper="1.047198" effort="10.0" velocity="1.5"/>
  </joint>

  <joint name="joint_3" type="revolute">
    <origin xyz="0.23441 -0.00016737 0" rpy="0 0 0"/>
    <parent link="Link_2"/>
    <child link="Link_3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.047198" upper="1.047198" effort="10.0" velocity="1.5"/>
  </joint>

  <joint name="joint_4" type="revolute">
    <origin xyz="0.047976 0.10644 0" rpy="-1.5708 0 0"/>
    <parent link="Link_3"/>
    <child link="Link_4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.792527" upper="2.792527" effort="8.0" velocity="2.0"/>
  </joint>

  <joint name="joint_5" type="revolute">
