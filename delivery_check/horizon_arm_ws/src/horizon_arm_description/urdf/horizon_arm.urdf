<?xml version="1.0"?>
<robot name="horizon_arm">
  <material name="horizon_dark">
    <color rgba="0.13 0.15 0.17 1.0"/>
  </material>
  <material name="horizon_light">
    <color rgba="0.78 0.82 0.86 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/base_link.STL"/>
      </geometry>
      <material name="horizon_dark"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="Link_1">
