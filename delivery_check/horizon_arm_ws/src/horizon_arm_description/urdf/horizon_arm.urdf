  </link>

  <link name="Link_4">
    <visual>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_4.STL"/>
      </geometry>
      <material name="horizon_dark"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_4.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="Link_5">
    <visual>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_5.STL"/>
      </geometry>
      <material name="horizon_dark"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://horizon_arm_description/meshes/Link_5.STL"/>
